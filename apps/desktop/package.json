{
    "name": "@kabootar/desktop",
    "version": "0.1.0",
    "private": true,
    "description": "Kabootar Desktop — cross-platform API testing client",
    "main": "dist-electron/main.js",
    "type": "module",
    "license": "MIT",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build && tsc -p tsconfig.electron.json",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "clean": "rm -rf dist dist-electron",
        "package": "electron-builder"
    },
    "dependencies": {
        "@kabootar/core": "workspace:*",
        "@kabootar/git-sync": "workspace:*",
        "@kabootar/test-runner": "workspace:*",
        "react": "^18.3.0",
        "react-dom": "^18.3.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.0",
        "autoprefixer": "^10.5.0",
        "electron": "^30.1.0",
        "electron-builder": "^24.13.0",
        "lucide-react": "^1.17.0",
        "postcss": "^8.5.15",
        "tailwindcss": "^4.3.0",
        "typescript": "^5.5.0",
        "vite": "^5.4.0",
        "vite-plugin-electron": "^0.28.0"
    },
    "build": {
        "extends": "./electron-builder.yml"
    }
}