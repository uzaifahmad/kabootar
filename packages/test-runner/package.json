{
    "name": "@kabootar/test-runner",
    "version": "0.1.0",
    "description": "JavaScript test runner with sandboxed execution for Kabootar API tests",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "license": "MIT",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@kabootar/core": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "typescript": "^5.5.0",
        "vitest": "^2.0.0"
    }
}