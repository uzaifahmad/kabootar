{
  "name": "kabootar",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source API testing platform — desktop client, self-hostable backend, Git-first collections, JS test runner, and CI/CD integration.",
  "author": "Kabootar Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kabootar-dev/kabootar.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev:desktop": "pnpm --filter @kabootar/desktop dev",
    "dev:server": "cd apps/server && go run .",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}